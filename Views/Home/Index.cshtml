@{
    ViewData["Title"] = "Restaurant Reservations";
}

<!-- Hero Section -->
<div class="hero-section bg-primary text-white py-5 mb-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-3 fw-bold mb-4">
                    🍽️ Restaurant Reservations
                </h1>
                <p class="lead mb-4">
                    Discover amazing restaurants and make reservations with ease. 
                    From cozy cafes to fine dining, find your perfect dining experience.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Restaurants" asp-action="Index" class="btn btn-light btn-lg">
                        <i class="fas fa-search"></i> Browse Restaurants
                    </a>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Reservations" asp-action="Index" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-calendar-check"></i> My Reservations
                        </a>
                    }
                    else
                    {
                        <a href="/Identity/Account/Register" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-user-plus"></i> Join Now
                        </a>
                    }
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <div class="hero-illustration">
                    <i class="fas fa-utensils fa-10x opacity-75"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Search Section -->
<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0">
                <div class="card-body p-4">
                    <h3 class="text-center mb-4">
                        <i class="fas fa-search text-primary"></i> Find Your Perfect Restaurant
                    </h3>
                    <form asp-controller="Restaurants" asp-action="Index" method="get">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text">
                                        <i class="fas fa-utensils"></i>
                                    </span>
                                    <input type="text" name="search" class="form-control" 
                                           placeholder="Search by restaurant name, cuisine, or location...">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <button type="submit" class="btn btn-primary btn-lg w-100">
                                    <i class="fas fa-search"></i> Search Now
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container mb-5">
    <div class="row text-center mb-5">
        <div class="col-12">
            <h2 class="display-5 fw-bold">Why Choose Our Platform?</h2>
            <p class="lead text-muted">Everything you need for the perfect dining experience</p>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="fas fa-search fa-3x text-primary"></i>
                    </div>
                    <h4>Easy Discovery</h4>
                    <p class="text-muted">
                        Search and filter restaurants by name, location, cuisine type, and more. 
                        Find exactly what you're looking for.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="fas fa-calendar-check fa-3x text-success"></i>
                    </div>
                    <h4>Instant Reservations</h4>
                    <p class="text-muted">
                        Book your table in seconds. Choose your date, time, and party size. 
                        Get confirmation from the restaurant quickly.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="fas fa-shield-alt fa-3x text-warning"></i>
                    </div>
                    <h4>Secure & Reliable</h4>
                    <p class="text-muted">
                        Your reservations are secure and reliable. Track your booking status 
                        and manage your dining plans effortlessly.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- User Role Sections -->
@if (User.Identity.IsAuthenticated)
{
    <div class="container mb-5">
        <div class="row">
            @if (User.IsInRole("Admin"))
            {
                <div class="col-md-6 mb-4">
                    <div class="card border-primary">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-cog"></i> Admin Dashboard</h5>
                        </div>
                        <div class="card-body">
                            <p>Manage the entire system, users, and restaurants.</p>
                            <div class="d-flex gap-2">
                                <a asp-controller="Admin" asp-action="Index" class="btn btn-primary">
                                    <i class="fas fa-tachometer-alt"></i> Dashboard
                                </a>
                                <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-primary">
                                    <i class="fas fa-users"></i> Users
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (User.IsInRole("RestaurantOwner"))
            {
                <div class="col-md-6 mb-4">
                    <div class="card border-success">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0"><i class="fas fa-store"></i> Restaurant Owner</h5>
                        </div>
                        <div class="card-body">
                            <p>Manage your restaurants and reservations.</p>
                            <div class="d-flex gap-2">
                                <a asp-controller="Reservations" asp-action="ManageReservations" class="btn btn-success">
                                    <i class="fas fa-calendar-check"></i> Reservations
                                </a>
                                <a asp-controller="Restaurants" asp-action="Create" class="btn btn-outline-success">
                                    <i class="fas fa-plus"></i> Add Restaurant
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (User.IsInRole("User"))
            {
                <div class="col-md-6 mb-4">
                    <div class="card border-info">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0"><i class="fas fa-user"></i> Welcome Back!</h5>
                        </div>
                        <div class="card-body">
                            <p>Ready to discover great restaurants?</p>
                            <div class="d-flex gap-2">
                                <a asp-controller="Restaurants" asp-action="Index" class="btn btn-info">
                                    <i class="fas fa-utensils"></i> Browse Restaurants
                                </a>
                                <a asp-controller="Reservations" asp-action="Index" class="btn btn-outline-info">
                                    <i class="fas fa-list"></i> My Reservations
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <!-- Call to Action for Non-authenticated Users -->
    <div class="container mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow-lg">
                    <div class="card-body text-center p-5">
                        <h3 class="mb-4">Ready to Get Started?</h3>
                        <p class="lead mb-4">Join our community and start making reservations today!</p>
                        <div class="d-flex justify-content-center gap-3">
                            <a href="/Identity/Account/Register" class="btn btn-primary btn-lg">
                                <i class="fas fa-user-plus"></i> Sign Up Free
                            </a>
                            <a href="/Identity/Account/Login" class="btn btn-outline-primary btn-lg">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%);
    }
    .feature-icon {
        transition: transform 0.3s ease;
    }
    .card:hover .feature-icon {
        transform: translateY(-5px);
    }
    .hero-illustration {
        animation: float 3s ease-in-out infinite;
    }
</style>
