@model IEnumerable<proekt_za_6ca.Data.Entities.Restaurants>

@{
    ViewData["Title"] = "Restaurants";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-4">🍽️ Restaurants</h1>
            <p class="lead">Discover amazing restaurants and make your reservation</p>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin") || User.IsInRole("RestaurantOwner"))
            {
                <a asp-action="Create" class="btn btn-success btn-lg">
                    <i class="fas fa-plus"></i> Add Restaurant
                </a>
            }
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form method="get" asp-action="Index">
                        <div class="row g-3">
                            <!-- Main Search -->
                            <div class="col-lg-5">
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-search"></i>
                                    </span>
                                    <input type="text" 
                                           name="search" 
                                           id="searchInput"
                                           class="form-control" 
                                           placeholder="Search by name, description, or address..." 
                                           value="@ViewBag.SearchTerm">
                                </div>
                            </div>

                            <!-- Location Filter -->
                            <div class="col-lg-3">
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-map-marker-alt"></i>
                                    </span>
                                    <input type="text" 
                                           name="location" 
                                           class="form-control" 
                                           placeholder="Filter by location..." 
                                           value="@ViewBag.LocationFilter">
                                </div>
                            </div>

                            <!-- Sort Options -->
                            <div class="col-lg-2">
                                <select name="sortBy" class="form-select">
                                    <option value="">Sort by Name (A-Z)</option>
                                    <option value="name_desc" selected="@(ViewBag.CurrentSort == "name_desc")">Name (Z-A)</option>
                                    <option value="location" selected="@(ViewBag.CurrentSort == "location")">Location (A-Z)</option>
                                    <option value="location_desc" selected="@(ViewBag.CurrentSort == "location_desc")">Location (Z-A)</option>
                                    <option value="newest" selected="@(ViewBag.CurrentSort == "newest")">Newest First</option>
                                    <option value="oldest" selected="@(ViewBag.CurrentSort == "oldest")">Oldest First</option>
                                </select>
                            </div>

                            <!-- Action Buttons -->
                            <div class="col-lg-2">
                                <div class="row g-1">
                                    <div class="col-6">
                                        <button type="submit" class="btn btn-primary w-100" title="Search">
                                            <i class="fas fa-search"></i>
                                        </button>
                                    </div>
                                    <div class="col-6">
                                        <a asp-action="Index" class="btn btn-outline-secondary w-100" title="Clear">
                                            <i class="fas fa-times"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Results Summary -->
    <div class="row mb-3">
        <div class="col-md-8">
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm) || !string.IsNullOrEmpty(ViewBag.LocationFilter))
            {
                <div class="alert alert-info mb-2">
                    <i class="fas fa-info-circle"></i> 
                    <strong>@ViewBag.TotalResults</strong> restaurant(s) found
                    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                    {
                        <span> for "<strong>@ViewBag.SearchTerm</strong>"</span>
                    }
                    @if (!string.IsNullOrEmpty(ViewBag.LocationFilter))
                    {
                        <span> in "<strong>@ViewBag.LocationFilter</strong>"</span>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-2">
                    <i class="fas fa-utensils"></i> Showing <strong>@ViewBag.TotalResults</strong> restaurant(s)
                </p>
            }
        </div>
        <div class="col-md-4 text-end">
            <!-- Quick Sort Links -->
            <div class="btn-group btn-group-sm" role="group">
                @{
                    var nameButtonClass = string.IsNullOrEmpty(ViewBag.CurrentSort) ? "btn btn-primary" : "btn btn-outline-secondary";
                    var newestButtonClass = ViewBag.CurrentSort == "newest" ? "btn btn-primary" : "btn btn-outline-secondary";
                }
                <a asp-action="Index" asp-route-search="@ViewBag.SearchTerm" asp-route-location="@ViewBag.LocationFilter" 
                   class="@nameButtonClass">
                    Name <i class="fas fa-sort-alpha-up"></i>
                </a>
                <a asp-action="Index" asp-route-search="@ViewBag.SearchTerm" asp-route-location="@ViewBag.LocationFilter" asp-route-sortBy="newest"
                   class="@newestButtonClass">
                    Newest <i class="fas fa-sort-numeric-down"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Search Results Info -->
    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
    {
        <div class="row mb-3">
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> 
                    Showing results for "<strong>@ViewBag.SearchTerm</strong>" - <strong>@Model.Count()</strong> restaurant(s) found
                </div>
            </div>
        </div>
    }

    <!-- Restaurants Grid -->
    <div class="row">
        @if (Model.Any())
        {
            @foreach (var restaurant in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm restaurant-card">
                        <!-- Restaurant Image -->
                        <div class="card-img-top-container" style="height: 200px; overflow: hidden;">
                            @if (!string.IsNullOrEmpty(restaurant.ImageUrl))
                            {
                                <img src="@restaurant.ImageUrl" 
                                     class="card-img-top" 
                                     alt="@restaurant.Title"
                                     style="width: 100%; height: 100%; object-fit: cover;"
                                     onerror="this.src='/images/restaurant-placeholder.jpg'">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                                    <i class="fas fa-utensils fa-3x text-muted"></i>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <!-- Restaurant Name -->
                            <h5 class="card-title">@restaurant.Title</h5>
                            
                            <!-- Description -->
                            <p class="card-text text-muted">
                                @(restaurant.Description.Length > 100 
                                    ? restaurant.Description.Substring(0, 100) + "..." 
                                    : restaurant.Description)
                            </p>

                            <!-- Address -->
                            <p class="card-text">
                                <small class="text-muted">
                                    <i class="fas fa-map-marker-alt"></i> @restaurant.Address
                                </small>
                            </p>

                            <!-- Owner Info (for admins/owners) -->
                            @if (User.IsInRole("Admin") || User.IsInRole("RestaurantOwner"))
                            {
                                <p class="card-text">
                                    <small class="text-info">
                                        <i class="fas fa-user"></i> Owner: @restaurant.Owner?.Email
                                    </small>
                                </p>
                            }

                            <!-- Action Buttons -->
                            <div class="mt-auto">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <a asp-action="Details" asp-route-id="@restaurant.Id" 
                                           class="btn btn-primary w-100">
                                            <i class="fas fa-eye"></i> View & Book
                                        </a>
                                    </div>
                                    @if (User.IsInRole("Admin") || (User.IsInRole("RestaurantOwner") && restaurant.Owner?.Email == User.Identity.Name))
                                    {
                                        <div class="col-3">
                                            <a asp-action="Edit" asp-route-id="@restaurant.Id" 
                                               class="btn btn-outline-warning w-100" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        </div>
                                        <div class="col-3">
                                            <a asp-action="Delete" asp-route-id="@restaurant.Id" 
                                               class="btn btn-outline-danger w-100" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="fas fa-search fa-4x text-muted mb-3"></i>
                    <h3 class="text-muted">No restaurants found</h3>
                    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                    {
                        <p class="text-muted">Try adjusting your search criteria</p>
                        <a asp-action="Index" class="btn btn-primary">View All Restaurants</a>
                    }
                    else
                    {
                        <p class="text-muted">No restaurants are available at the moment</p>
                        @if (User.IsInRole("Admin") || User.IsInRole("RestaurantOwner"))
                        {
                            <a asp-action="Create" class="btn btn-success">Add First Restaurant</a>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    .restaurant-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .restaurant-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
    }
    .card-img-top-container {
        position: relative;
    }
</style>
