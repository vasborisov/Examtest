@model proekt_za_6ca.Data.Entities.Restaurants

@{
    ViewData["Title"] = Model.Title;
}

<div class="container-fluid">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Restaurants</a></li>
                    <li class="breadcrumb-item active">@Model.Title</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <!-- Restaurant Information -->
        <div class="col-lg-8">
            <!-- Restaurant Image -->
            <div class="card mb-4 shadow-sm">
                <div class="card-img-top-container" style="height: 400px; overflow: hidden;">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" 
                             class="card-img-top" 
                             alt="@Model.Title"
                             style="width: 100%; height: 100%; object-fit: cover;">
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                            <i class="fas fa-utensils fa-5x text-muted"></i>
                        </div>
                    }
                </div>
            </div>

            <!-- Restaurant Details -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header">
                    <h2 class="mb-0">
                        <i class="fas fa-utensils text-primary"></i> @Model.Title
                    </h2>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <h5><i class="fas fa-info-circle text-info"></i> About</h5>
                            <p class="lead">@Model.Description</p>

                            <h5><i class="fas fa-map-marker-alt text-danger"></i> Location</h5>
                            <p>
                                <strong>Address:</strong> @Model.Address<br>
                                <small class="text-muted">
                                    Coordinates: @Model.Latitude.ToString("F6"), @Model.Longitude.ToString("F6")
                                </small>
                            </p>
                        </div>
                        <div class="col-md-4">
                            <!-- Map placeholder -->
                            <div class="card">
                                <div class="card-header">
                                    <small><i class="fas fa-map"></i> Location Map</small>
                                </div>
                                <div class="card-body text-center bg-light" style="height: 200px;">
                                    <div class="d-flex align-items-center justify-content-center h-100">
                                        <div>
                                            <i class="fas fa-map-marked-alt fa-3x text-muted"></i>
                                            <p class="mt-2 mb-0"><small>Map integration available</small></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Admin/Owner Actions -->
                    @if (User.IsInRole("Admin") || (User.IsInRole("RestaurantOwner") && Model.Owner?.Email == User.Identity.Name))
                    {
                        <div class="mt-4 pt-3 border-top">
                            <h6><i class="fas fa-cog"></i> Management Actions</h6>
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">
                                    <i class="fas fa-edit"></i> Edit Restaurant
                                </a>
                                <a asp-controller="Reservations" asp-action="ManageReservations" class="btn btn-outline-info">
                                    <i class="fas fa-calendar-check"></i> Manage Reservations
                                </a>
                                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Reservation Section -->
        <div class="col-lg-4">
            @if (ViewBag.IsAuthenticated)
            {
                <div class="card shadow-sm sticky-top" style="top: 20px;">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-calendar-plus"></i> Make a Reservation
                        </h5>
                    </div>
                    <div class="card-body">
                        <!-- Success/Error Messages -->
                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show">
                                <i class="fas fa-check-circle"></i> @TempData["Success"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }
                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show">
                                <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <!-- Reservation Form -->
                        <form asp-action="MakeReservation" method="post" asp-antiforgery="true">
                            <input type="hidden" name="restaurantId" value="@Model.Id" />
                            
                            <div class="mb-3">
                                <label for="reservationTime" class="form-label">
                                    <i class="fas fa-calendar-alt"></i> Date & Time
                                </label>
                                <input type="datetime-local" 
                                       id="reservationTime" 
                                       name="reservationTime" 
                                       class="form-control" 
                                       value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-ddTHH:mm")"
                                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" 
                                       required>
                                <small class="form-text text-muted">Select your preferred date and time</small>
                            </div>

                            <div class="mb-3">
                                <label for="peopleCount" class="form-label">
                                    <i class="fas fa-users"></i> Number of People
                                </label>
                                <select id="peopleCount" name="peopleCount" class="form-select" required>
                                    @for (int i = 1; i <= 20; i++)
                                    {
                                        <option value="@i" selected="@(i == 2)">
                                            @i @(i == 1 ? "person" : "people")
                                        </option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="comment" class="form-label">
                                    <i class="fas fa-comment"></i> Special Requests (Optional)
                                </label>
                                <textarea id="comment" 
                                          name="comment" 
                                          class="form-control" 
                                          rows="3" 
                                          placeholder="Any special requests or dietary requirements..."></textarea>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-check"></i> Submit Reservation
                                </button>
                            </div>
                        </form>

                        <div class="mt-3 text-center">
                            <small class="text-muted">
                                <i class="fas fa-info-circle"></i> 
                                Your reservation will be pending approval by the restaurant
                            </small>
                        </div>
                    </div>
                </div>

                <!-- My Reservations Link -->
                <div class="mt-3 text-center">
                    <a asp-controller="Reservations" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-list"></i> View My Reservations
                    </a>
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">
                            <i class="fas fa-sign-in-alt"></i> Login Required
                        </h5>
                    </div>
                    <div class="card-body text-center">
                        <p>Please login to make a reservation</p>
                        <div class="d-grid gap-2">
                            <a href="/Identity/Account/Login" class="btn btn-primary">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                            <a href="/Identity/Account/Register" class="btn btn-outline-secondary">
                                <i class="fas fa-user-plus"></i> Register
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Back Button -->
    <div class="row mt-4">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Restaurants
            </a>
        </div>
    </div>
</div>
