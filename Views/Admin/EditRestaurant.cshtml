@model proekt_za_6ca.Data.Entities.Restaurants

@{
    ViewData["Title"] = "Edit Restaurant";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Admin Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Restaurants">Restaurant Management</a></li>
                    <li class="breadcrumb-item active">Edit Restaurant</li>
                </ol>
            </nav>
            <h1 class="display-5">
                <i class="fas fa-edit text-primary"></i> Edit Restaurant
            </h1>
            <p class="lead text-muted">Update restaurant information</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-utensils"></i> Restaurant Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <form asp-action="EditRestaurant" method="post">
                        <input asp-for="Id" type="hidden" />
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Title" class="form-control form-control-lg" placeholder="Restaurant Name">
                                    <label asp-for="Title" class="form-label">
                                        <i class="fas fa-utensils"></i> Restaurant Name
                                    </label>
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <select asp-for="OwnerId" class="form-select form-select-lg" asp-items="ViewData["OwnerId"] as SelectList">
                                        <option value="">Select Owner...</option>
                                    </select>
                                    <label class="form-label">
                                        <i class="fas fa-user-tie"></i> Restaurant Owner
                                    </label>
                                    <span asp-validation-for="OwnerId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-floating">
                                <textarea asp-for="Description" class="form-control" placeholder="Description" style="height: 120px"></textarea>
                                <label asp-for="Description" class="form-label">
                                    <i class="fas fa-align-left"></i> Description
                                </label>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-floating">
                                <input asp-for="Address" class="form-control form-control-lg" placeholder="Address">
                                <label asp-for="Address" class="form-label">
                                    <i class="fas fa-map-marker-alt"></i> Address
                                </label>
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Latitude" class="form-control form-control-lg" placeholder="Latitude" step="any">
                                    <label asp-for="Latitude" class="form-label">
                                        <i class="fas fa-crosshairs"></i> Latitude
                                    </label>
                                    <span asp-validation-for="Latitude" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Longitude" class="form-control form-control-lg" placeholder="Longitude" step="any">
                                    <label asp-for="Longitude" class="form-label">
                                        <i class="fas fa-crosshairs"></i> Longitude
                                    </label>
                                    <span asp-validation-for="Longitude" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-floating">
                                <input asp-for="ImageUrl" class="form-control form-control-lg" placeholder="Image URL">
                                <label asp-for="ImageUrl" class="form-label">
                                    <i class="fas fa-image"></i> Image URL
                                </label>
                                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                            </div>
                            <small class="text-muted">Enter a URL to an image of the restaurant</small>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Restaurants" class="btn btn-secondary btn-lg">
                                <i class="fas fa-arrow-left"></i> Back to Restaurants
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save"></i> Update Restaurant
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}