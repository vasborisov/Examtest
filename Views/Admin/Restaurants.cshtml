@model IEnumerable<proekt_za_6ca.Data.Entities.Restaurants>

@{
    ViewData["Title"] = "Restaurant Management";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Admin Dashboard</a></li>
                    <li class="breadcrumb-item active">Restaurant Management</li>
                </ol>
            </nav>
            <h1 class="display-5">
                <i class="fas fa-utensils text-success"></i> Restaurant Management
            </h1>
            <p class="lead text-muted">Manage all restaurants in the system</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="CreateRestaurant" class="btn btn-success btn-lg">
                <i class="fas fa-plus"></i> Add New Restaurant
            </a>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Restaurants Grid -->
    <div class="row">
        @if (Model.Any())
        {
            @foreach (var restaurant in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm">
                        <!-- Restaurant Image -->
                        <div class="card-img-top-container" style="height: 200px; overflow: hidden;">
                            @if (!string.IsNullOrEmpty(restaurant.ImageUrl))
                            {
                                <img src="@restaurant.ImageUrl" 
                                     class="card-img-top" 
                                     alt="@restaurant.Title"
                                     style="width: 100%; height: 100%; object-fit: cover;"
                                     onerror="this.src='/images/restaurant-placeholder.jpg'">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                                    <i class="fas fa-utensils fa-3x text-muted"></i>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <!-- Restaurant Name -->
                            <h5 class="card-title">@restaurant.Title</h5>
                            
                            <!-- Description -->
                            <p class="card-text text-muted">
                                @(restaurant.Description.Length > 100 
                                    ? restaurant.Description.Substring(0, 100) + "..." 
                                    : restaurant.Description)
                            </p>

                            <!-- Details -->
                            <div class="mb-3">
                                <p class="card-text mb-1">
                                    <small class="text-muted">
                                        <i class="fas fa-map-marker-alt"></i> @restaurant.Address
                                    </small>
                                </p>
                                <p class="card-text mb-1">
                                    <small class="text-info">
                                        <i class="fas fa-user"></i> Owner: @restaurant.Owner?.Email
                                    </small>
                                </p>
                                <p class="card-text mb-1">
                                    <small class="text-muted">
                                        <i class="fas fa-calendar"></i> Created: @restaurant.CreatedOn.ToString("MMM dd, yyyy")
                                    </small>
                                </p>
                            </div>

                            <!-- Action Buttons -->
                            <div class="mt-auto">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <a asp-controller="Restaurants" asp-action="Details" asp-route-id="@restaurant.Id" 
                                           class="btn btn-primary w-100">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </div>
                                    <div class="col-3">
                                        <a asp-action="EditRestaurant" asp-route-id="@restaurant.Id" 
                                           class="btn btn-outline-warning w-100" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </div>
                                    <div class="col-3">
                                        <a asp-action="DeleteRestaurant" asp-route-id="@restaurant.Id" 
                                           class="btn btn-outline-danger w-100" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="fas fa-utensils fa-4x text-muted mb-3"></i>
                    <h3 class="text-muted">No restaurants found</h3>
                    <p class="text-muted">Start by creating the first restaurant</p>
                    <a asp-action="CreateRestaurant" class="btn btn-success btn-lg">
                        <i class="fas fa-plus"></i> Create First Restaurant
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Back Button -->
    <div class="row mt-4">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
    }
</style>