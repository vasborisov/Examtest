@model IEnumerable<proekt_za_6ca.Controllers.UserWithRoleViewModel>

@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Admin Dashboard</a></li>
                    <li class="breadcrumb-item active">User Management</li>
                </ol>
            </nav>
            <h1 class="display-5">
                <i class="fas fa-users text-primary"></i> User Management
            </h1>
            <p class="lead text-muted">Manage system users and their roles</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="CreateUser" class="btn btn-success btn-lg">
                <i class="fas fa-user-plus"></i> Add New User
            </a>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Users Table -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-list"></i> All Users (@Model.Count())
                    </h5>
                    <div>
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i> Click on a user to view details
                        </small>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th><i class="fas fa-user"></i> Name</th>
                                        <th><i class="fas fa-envelope"></i> Email</th>
                                        <th><i class="fas fa-user-tag"></i> Role</th>
                                        <th><i class="fas fa-calendar"></i> Status</th>
                                        <th class="text-center"><i class="fas fa-cogs"></i> Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var userViewModel in Model)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-circle me-2">
                                                        @if (!string.IsNullOrEmpty(userViewModel.User.FirstName))
                                                        {
                                                            <span>@userViewModel.User.FirstName.Substring(0, 1)@userViewModel.User.LastName?.Substring(0, 1)</span>
                                                        }
                                                        else
                                                        {
                                                            <i class="fas fa-user"></i>
                                                        }
                                                    </div>
                                                    <div>
                                                        <strong>@userViewModel.User.FirstName @userViewModel.User.LastName</strong>
                                                        <br>
                                                        <small class="text-muted">@userViewModel.User.UserName</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span>@userViewModel.User.Email</span>
                                                @if (userViewModel.User.EmailConfirmed)
                                                {
                                                    <i class="fas fa-check-circle text-success ms-1" title="Verified"></i>
                                                }
                                                else
                                                {
                                                    <i class="fas fa-exclamation-circle text-warning ms-1" title="Unverified"></i>
                                                }
                                            </td>
                                            <td>
                                                @if (userViewModel.Roles.Any())
                                                {
                                                    @foreach (var role in userViewModel.Roles)
                                                    {
                                                        <span class="badge bg-@(role switch { "Admin" => "danger", "RestaurantOwner" => "success", _ => "primary" }) me-1">
                                                            <i class="fas fa-@(role switch { "Admin" => "crown", "RestaurantOwner" => "store", _ => "user" })"></i> @role
                                                        </span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">No Role</span>
                                                }
                                            </td>
                                            <td>
                                                @if (userViewModel.User.EmailConfirmed)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Pending</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <a asp-action="EditUser" asp-route-id="@userViewModel.User.Id" 
                                                       class="btn btn-outline-warning" title="Edit User">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    @if (!userViewModel.Roles.Contains("Admin"))
                                                    {
                                                        <a asp-action="DeleteUser" asp-route-id="@userViewModel.User.Id" 
                                                           class="btn btn-outline-danger" title="Delete User">
                                                            <i class="fas fa-trash"></i>
                                                        </a>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-users fa-4x text-muted mb-3"></i>
                            <h4 class="text-muted">No users found</h4>
                            <p class="text-muted">Start by creating your first user</p>
                            <a asp-action="CreateUser" class="btn btn-success">
                                <i class="fas fa-plus"></i> Create First User
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Back Button -->
    <div class="row mt-4">
        <div class="col-12">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>

<style>
    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #007bff, #6610f2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 0.875rem;
    }
    
    .table tbody tr {
        transition: background-color 0.2s ease;
    }
    
    .table tbody tr:hover {
        background-color: rgba(0,123,255,0.05);
    }
    
    .btn-group .btn {
        transition: all 0.2s ease;
    }
</style>