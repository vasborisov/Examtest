@model proekt_za_6ca.ViewModels.RestaurantCreateViewModel

@{
    ViewData["Title"] = "Create Restaurant";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Admin Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Restaurants">Restaurant Management</a></li>
                    <li class="breadcrumb-item active">Create Restaurant</li>
                </ol>
            </nav>
            <h1 class="display-5">
                <i class="fas fa-plus text-success"></i> Create New Restaurant
            </h1>
            <p class="lead text-muted">Add a new restaurant to the system</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-utensils"></i> Restaurant Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CreateRestaurant" method="post" enctype="multipart/form-data" asp-antiforgery="true">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row">
                            <!-- Basic Information -->
                            <div class="col-lg-6">
                                <h6 class="text-muted mb-3">
                                    <i class="fas fa-info-circle"></i> Basic Information
                                </h6>

                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label">
                                        <i class="fas fa-utensils"></i> Restaurant Name
                                    </label>
                                    <input asp-for="Title" class="form-control form-control-lg" placeholder="Enter restaurant name" maxlength="64">
                                    <span asp-validation-for="Title" class="text-danger"></span>
                                    <small class="form-text text-muted">Maximum 64 characters</small>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label">
                                        <i class="fas fa-align-left"></i> Description
                                    </label>
                                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the restaurant, cuisine type, ambiance, etc." maxlength="255"></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                    <small class="form-text text-muted">Maximum 255 characters</small>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ImageFile" class="form-label">
                                        <i class="fas fa-upload"></i> Upload Photo
                                    </label>
                                    <input asp-for="ImageFile" type="file" class="form-control" accept="image/*">
                                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                                    <small class="form-text text-muted">Upload a photo (JPG, PNG, GIF, WebP) - Max 2MB</small>
                                </div>

                                <div class="text-center mb-3">
                                    <span class="text-muted">OR</span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ImageUrl" class="form-label">
                                        <i class="fas fa-link"></i> Photo URL
                                    </label>
                                    <input asp-for="ImageUrl" class="form-control form-control-lg" placeholder="https://example.com/restaurant-photo.jpg">
                                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                                    <small class="form-text text-muted">Or provide an image URL</small>
                                </div>
                            </div>

                            <!-- Location & Owner -->
                            <div class="col-lg-6">
                                <h6 class="text-muted mb-3">
                                    <i class="fas fa-map-marker-alt"></i> Location & Management
                                </h6>

                                <div class="mb-3">
                                    <label asp-for="Address" class="form-label">
                                        <i class="fas fa-map-marker-alt"></i> Address
                                    </label>
                                    <input asp-for="Address" class="form-control form-control-lg" placeholder="Enter full address">
                                    <span asp-validation-for="Address" class="text-danger"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Latitude" class="form-label">
                                                <i class="fas fa-globe"></i> Latitude
                                            </label>
                                            <input asp-for="Latitude" class="form-control" placeholder="42.3601" step="any">
                                            <span asp-validation-for="Latitude" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="Longitude" class="form-label">
                                                <i class="fas fa-globe"></i> Longitude
                                            </label>
                                            <input asp-for="Longitude" class="form-control" placeholder="-71.0589" step="any">
                                            <span asp-validation-for="Longitude" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="OwnerId" class="form-label">
                                        <i class="fas fa-user-tie"></i> Restaurant Owner
                                    </label>
                                    <select asp-for="OwnerId" class="form-select form-select-lg" asp-items="ViewBag.RestaurantOwners">
                                        <option value="">Select a restaurant owner...</option>
                                    </select>
                                    <span asp-validation-for="OwnerId" class="text-danger"></span>
                                    <small class="form-text text-muted">Choose who will manage this restaurant</small>
                                </div>

                                <!-- Coordinate Helper -->
                                <div class="alert alert-info">
                                    <h6><i class="fas fa-lightbulb"></i> Coordinate Helper</h6>
                                    <p class="mb-0 small">
                                        You can find latitude and longitude coordinates using 
                                        <a href="https://www.google.com/maps" target="_blank" class="alert-link">Google Maps</a>. 
                                        Right-click on the location and select "What's here?"
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <hr>
                                <div class="d-flex justify-content-between">
                                    <a asp-action="Restaurants" class="btn btn-secondary btn-lg">
                                        <i class="fas fa-arrow-left"></i> Back to Restaurants
                                    </a>
                                    <div>
                                        <button type="reset" class="btn btn-outline-secondary btn-lg me-2">
                                            <i class="fas fa-undo"></i> Reset Form
                                        </button>
                                        <button type="submit" class="btn btn-success btn-lg">
                                            <i class="fas fa-plus"></i> Create Restaurant
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Form validation enhancement
            const form = document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function(e) {
                    const submitBtn = this.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating Restaurant...';
                        submitBtn.disabled = true;
                    }
                });
            }

            // Character count for text areas
            const description = document.querySelector('textarea[name="Description"]');
            if (description) {
                const maxLength = 255;
                const counter = document.createElement('div');
                counter.className = 'form-text text-muted';
                counter.style.textAlign = 'right';
                description.parentNode.appendChild(counter);
                
                function updateCounter() {
                    const remaining = maxLength - description.value.length;
                    counter.textContent = `${remaining} characters remaining`;
                    counter.className = remaining < 50 ? 'form-text text-warning' : 'form-text text-muted';
                }
                
                description.addEventListener('input', updateCounter);
                updateCounter();
            }
        });
    </script>
}