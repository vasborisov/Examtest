@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-4">
                        <i class="fas fa-tachometer-alt text-primary"></i> Admin Dashboard
                    </h1>
                    <p class="lead text-muted">System overview and management tools</p>
                </div>
                <div class="text-end">
                    <small class="text-muted">
                        <i class="fas fa-clock"></i> Last updated: @DateTime.Now.ToString("MMM dd, yyyy HH:mm")
                    </small>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title text-muted mb-2">Total Users</h6>
                            <h2 class="text-primary mb-0">@ViewBag.TotalUsers</h2>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-users fa-2x text-primary opacity-75"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title text-muted mb-2">Total Restaurants</h6>
                            <h2 class="text-success mb-0">@ViewBag.TotalRestaurants</h2>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-utensils fa-2x text-success opacity-75"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title text-muted mb-2">Total Reservations</h6>
                            <h2 class="text-info mb-0">@ViewBag.TotalReservations</h2>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-calendar-check fa-2x text-info opacity-75"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title text-muted mb-2">Pending Reservations</h6>
                            <h2 class="text-warning mb-0">@ViewBag.PendingReservations</h2>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-clock fa-2x text-warning opacity-75"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-bolt text-warning"></i> Quick Actions
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <a asp-action="Users" class="btn btn-outline-primary w-100 h-100 d-flex flex-column justify-content-center">
                                <i class="fas fa-users fa-2x mb-2"></i>
                                <span>Manage Users</span>
                            </a>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <a asp-action="CreateUser" class="btn btn-outline-success w-100 h-100 d-flex flex-column justify-content-center">
                                <i class="fas fa-user-plus fa-2x mb-2"></i>
                                <span>Add User</span>
                            </a>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <a asp-action="Restaurants" class="btn btn-outline-info w-100 h-100 d-flex flex-column justify-content-center">
                                <i class="fas fa-utensils fa-2x mb-2"></i>
                                <span>Manage Restaurants</span>
                            </a>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <a asp-action="CreateRestaurant" class="btn btn-outline-warning w-100 h-100 d-flex flex-column justify-content-center">
                                <i class="fas fa-plus fa-2x mb-2"></i>
                                <span>Add Restaurant</span>
                            </a>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <a asp-controller="Reservations" asp-action="Index" class="btn btn-outline-secondary w-100 h-100 d-flex flex-column justify-content-center">
                                <i class="fas fa-calendar-alt fa-2x mb-2"></i>
                                <span>View All Reservations</span>
                            </a>
                        </div>
                        <div class="col-lg-2 col-md-4 col-sm-6">
                            <a asp-controller="Restaurants" asp-action="Index" class="btn btn-outline-dark w-100 h-100 d-flex flex-column justify-content-center">
                                <i class="fas fa-search fa-2x mb-2"></i>
                                <span>Browse Restaurants</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Management Sections -->
    <div class="row">
        <!-- User Management Preview -->
        <div class="col-lg-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-users"></i> User Management
                    </h5>
                    <a asp-action="Users" class="btn btn-outline-light btn-sm">
                        <i class="fas fa-external-link-alt"></i> View All
                    </a>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="border-end">
                                <h4 class="text-primary mb-1">@ViewBag.TotalUsers</h4>
                                <small class="text-muted">Total Users</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="border-end">
                                <h4 class="text-success mb-1">Active</h4>
                                <small class="text-muted">Status</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <h4 class="text-info mb-1">3</h4>
                            <small class="text-muted">Roles</small>
                        </div>
                    </div>
                    <div class="mt-3">
                        <div class="d-grid gap-2 d-md-flex">
                            <a asp-action="CreateUser" class="btn btn-success flex-fill">
                                <i class="fas fa-plus"></i> Add New User
                            </a>
                            <a asp-action="Users" class="btn btn-outline-primary flex-fill">
                                <i class="fas fa-cog"></i> Manage Users
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Restaurant Management Preview -->
        <div class="col-lg-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-utensils"></i> Restaurant Management
                    </h5>
                    <a asp-action="Restaurants" class="btn btn-outline-light btn-sm">
                        <i class="fas fa-external-link-alt"></i> View All
                    </a>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="border-end">
                                <h4 class="text-success mb-1">@ViewBag.TotalRestaurants</h4>
                                <small class="text-muted">Total Restaurants</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="border-end">
                                <h4 class="text-warning mb-1">@ViewBag.PendingReservations</h4>
                                <small class="text-muted">Pending</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <h4 class="text-info mb-1">@ViewBag.TotalReservations</h4>
                            <small class="text-muted">Total Bookings</small>
                        </div>
                    </div>
                    <div class="mt-3">
                        <div class="d-grid gap-2 d-md-flex">
                            <a asp-action="CreateRestaurant" class="btn btn-success flex-fill">
                                <i class="fas fa-plus"></i> Add Restaurant
                            </a>
                            <a asp-action="Restaurants" class="btn btn-outline-primary flex-fill">
                                <i class="fas fa-cog"></i> Manage Restaurants
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
    }
    .btn {
        transition: all 0.2s ease;
    }
</style>