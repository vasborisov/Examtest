@model proekt_za_6ca.Controllers.CreateUserViewModel

@{
    ViewData["Title"] = "Create User";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Admin Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Users">User Management</a></li>
                    <li class="breadcrumb-item active">Create User</li>
                </ol>
            </nav>
            <h1 class="display-5">
                <i class="fas fa-user-plus text-success"></i> Create New User
            </h1>
            <p class="lead text-muted">Add a new user to the system</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-user-plus"></i> User Information
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CreateUser" method="post" asp-antiforgery="true">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row">
                            <!-- Personal Information -->
                            <div class="col-md-6">
                                <h6 class="text-muted mb-3">
                                    <i class="fas fa-user"></i> Personal Information
                                </h6>

                                <div class="mb-3">
                                    <label asp-for="FirstName" class="form-label">
                                        <i class="fas fa-user"></i> First Name
                                    </label>
                                    <input asp-for="FirstName" class="form-control form-control-lg" placeholder="Enter first name">
                                    <span asp-validation-for="FirstName" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="LastName" class="form-label">
                                        <i class="fas fa-user"></i> Last Name
                                    </label>
                                    <input asp-for="LastName" class="form-control form-control-lg" placeholder="Enter last name">
                                    <span asp-validation-for="LastName" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label">
                                        <i class="fas fa-envelope"></i> Email Address
                                    </label>
                                    <input asp-for="Email" class="form-control form-control-lg" placeholder="Enter email address">
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                    <small class="form-text text-muted">This will be used as the username</small>
                                </div>
                            </div>

                            <!-- Account Settings -->
                            <div class="col-md-6">
                                <h6 class="text-muted mb-3">
                                    <i class="fas fa-cog"></i> Account Settings
                                </h6>

                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label">
                                        <i class="fas fa-lock"></i> Password
                                    </label>
                                    <input asp-for="Password" class="form-control form-control-lg" placeholder="Enter password">
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                    <small class="form-text text-muted">Minimum 6 characters with letters and numbers</small>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Role" class="form-label">
                                        <i class="fas fa-user-tag"></i> User Role
                                    </label>
                                    <select asp-for="Role" class="form-select form-select-lg" asp-items="ViewBag.Roles">
                                        <option value="">Select a role...</option>
                                    </select>
                                    <span asp-validation-for="Role" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        <strong>User:</strong> Can make reservations<br>
                                        <strong>RestaurantOwner:</strong> Can manage restaurants and reservations
                                    </small>
                                </div>

                                <!-- Role Description -->
                                <div class="alert alert-info">
                                    <h6><i class="fas fa-info-circle"></i> Role Permissions</h6>
                                    <ul class="mb-0 small">
                                        <li><strong>User:</strong> Browse restaurants, make and manage reservations</li>
                                        <li><strong>RestaurantOwner:</strong> All User permissions + manage own restaurants and approve reservations</li>
                                        <li><strong>Admin:</strong> Full system access (cannot be created through this form)</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <hr>
                                <div class="d-flex justify-content-between">
                                    <a asp-action="Users" class="btn btn-secondary btn-lg">
                                        <i class="fas fa-arrow-left"></i> Back to Users
                                    </a>
                                    <div>
                                        <button type="reset" class="btn btn-outline-secondary btn-lg me-2">
                                            <i class="fas fa-undo"></i> Reset Form
                                        </button>
                                        <button type="submit" class="btn btn-success btn-lg">
                                            <i class="fas fa-plus"></i> Create User
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Add some interactivity
        document.addEventListener('DOMContentLoaded', function() {
            // Role selection helper
            const roleSelect = document.querySelector('select[name="Role"]');
            const roleInfo = document.querySelector('.alert-info');
            
            if (roleSelect) {
                roleSelect.addEventListener('change', function() {
                    // Could add dynamic role description updates here
                    console.log('Selected role:', this.value);
                });
            }
            
            // Form validation enhancement
            const form = document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function(e) {
                    const submitBtn = this.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating User...';
                        submitBtn.disabled = true;
                    }
                });
            }
        });
    </script>
}