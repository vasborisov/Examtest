@model proekt_za_6ca.ViewModels.UserWithRoleViewModel

@{
    ViewData["Title"] = "Delete User";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Admin Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Users">User Management</a></li>
                    <li class="breadcrumb-item active">Delete User</li>
                </ol>
            </nav>
            <h1 class="display-5 text-danger">
                <i class="fas fa-user-times"></i> Delete User
            </h1>
            <p class="lead text-muted">Are you sure you want to delete this user?</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="alert alert-warning border-0 shadow-sm" role="alert">
                <h4 class="alert-heading">
                    <i class="fas fa-exclamation-triangle"></i> Warning!
                </h4>
                <p class="mb-0">
                    This action cannot be undone. Deleting this user will permanently remove their account 
                    and may affect associated reservations and restaurants.
                </p>
            </div>

            <div class="card border-0 shadow-lg">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-user"></i> User Details
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-5">Name:</dt>
                                <dd class="col-7">@Model.User.FirstName @Model.User.LastName</dd>
                                
                                <dt class="col-5">Email:</dt>
                                <dd class="col-7">@Model.User.Email</dd>
                                
                                <dt class="col-5">Role:</dt>
                                <dd class="col-7">
                                    @if (Model.Roles.Any())
                                    {
                                        <span class="badge bg-primary">@string.Join(", ", Model.Roles)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No role assigned</span>
                                    }
                                </dd>
                                
                                <dt class="col-5">Created:</dt>
                                <dd class="col-7">@Model.User.EmailConfirmed</dd>
                            </dl>
                        </div>
                        <div class="col-md-6 text-center">
                            <div class="p-4 bg-light rounded">
                                <i class="fas fa-user-circle fa-5x text-muted mb-3"></i>
                                <h6 class="text-muted">User Account</h6>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Users" class="btn btn-secondary btn-lg">
                            <i class="fas fa-arrow-left"></i> Cancel
                        </a>
                        
                        <form asp-action="DeleteUserConfirmed" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@Model.User.Id" />
                            <button type="submit" class="btn btn-danger btn-lg" 
                                    onclick="return confirm('Are you absolutely sure you want to delete this user?')">
                                <i class="fas fa-trash-alt"></i> Delete User
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>