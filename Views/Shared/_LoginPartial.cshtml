@using Microsoft.AspNetCore.Identity
@using proekt_za_6ca.Data.Entities
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-white" href="#" id="userDropdown" role="button" 
           data-bs-toggle="dropdown" aria-expanded="false">
            <i class="fas fa-user-circle me-1"></i>
            Hello @(User.Identity?.Name?.Split('@')[0] ?? "User")!
        </a>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
            <li>
                <h6 class="dropdown-header">
                    <i class="fas fa-user me-1"></i>@User.Identity?.Name
                </h6>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                    <i class="fas fa-cog me-2"></i>Account Settings
                </a>
            </li>
            <li>
                <a class="dropdown-item" asp-controller="Reservations" asp-action="Index">
                    <i class="fas fa-calendar-alt me-2"></i>My Reservations
                </a>
            </li>
            @if (User.IsInRole("RestaurantOwner"))
            {
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item" asp-controller="Reservations" asp-action="ManageReservations">
                        <i class="fas fa-store me-2"></i>My Restaurant Dashboard
                    </a>
                </li>
            }
            @if (User.IsInRole("Admin"))
            {
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item" asp-controller="Admin" asp-action="Index">
                        <i class="fas fa-crown me-2"></i>Admin Dashboard
                    </a>
                </li>
            }
            <li><hr class="dropdown-divider"></li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="dropdown-item text-danger">
                        <i class="fas fa-sign-out-alt me-2"></i>Logout
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Login">
            <i class="fas fa-sign-in-alt me-1"></i>Login
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">
            <i class="fas fa-user-plus me-1"></i>Register
        </a>
    </li>
}
</ul>
